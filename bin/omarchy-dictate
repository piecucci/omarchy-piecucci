#!/usr/bin/env python3
"""
Voice dictation for Hyprland/Wayland using Vosk.
Supports toggle behavior via PID file and SIGTERM.
"""

import argparse
import json
import os
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

from vosk import Model, KaldiRecognizer, SetLogLevel

# Suppress Vosk logs
SetLogLevel(-1)

MODEL_PATH = Path.home() / ".local/share/vosk-models/vosk-model-small-en-us"
SAMPLE_RATE = 16000
PID_FILE = Path.home() / ".local/share/dictate.pid"

# Global flag to stop recording
stop_recording = False

def signal_handler(sig, frame):
    global stop_recording
    stop_recording = True

def get_default_source():
    """Get the default audio source for recording."""
    result = subprocess.run(
        ["pactl", "get-default-source"],
        capture_output=True, text=True
    )
    return result.stdout.strip()

def record_audio(duration=None):
    """Record audio from microphone. Returns audio data."""
    global stop_recording
    print("🎤 Recording... (press Enter or run again to stop)", file=sys.stderr, flush=True)
    
    with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tmp:
        tmp_path = tmp.name
    
    cmd = [
        "parecord",
        "--rate", str(SAMPLE_RATE),
        "--channels", "1",
        "--format", "s16le",
        "--device", "@DEFAULT_SOURCE@",
        tmp_path
    ]
    
    # Write PID to file for toggle
    PID_FILE.write_text(str(os.getpid()))
    
    # Set up signal handler for SIGTERM (used by toggle)
    signal.signal(signal.SIGTERM, signal_handler)
    
    proc = subprocess.Popen(cmd)
    
    # If in a terminal, wait for Enter
    if sys.stdin.isatty():
        import threading
        def wait_for_enter():
            global stop_recording
            try:
                input()
                stop_recording = True
            except EOFError:
                pass
        
        t = threading.Thread(target=wait_for_enter, daemon=True)
        t.start()
        
        while not stop_recording and proc.poll() is None:
            time.sleep(0.1)
    else:
        # If not in a terminal, wait for the signal
        while not stop_recording and proc.poll() is None:
            time.sleep(0.1)

    proc.terminate()
    proc.wait()
    
    if PID_FILE.exists():
        try:
            PID_FILE.unlink()
        except FileNotFoundError:
            pass
    
    return tmp_path

def transcribe(audio_path):
    """Transcribe audio file using Vosk."""
    if not MODEL_PATH.exists():
        print(f"Error: Model not found at {MODEL_PATH}", file=sys.stderr)
        sys.exit(1)
    
    model = Model(str(MODEL_PATH))
    rec = KaldiRecognizer(model, SAMPLE_RATE)
    
    # Convert to raw PCM using ffmpeg
    cmd = [
        "ffmpeg", "-loglevel", "quiet",
        "-i", audio_path,
        "-ar", str(SAMPLE_RATE),
        "-ac", "1",
        "-f", "s16le",
        "-"
    ]
    
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE)
    
    result_text = []
    while True:
        data = proc.stdout.read(4000)
        if len(data) == 0:
            break
        if rec.AcceptWaveform(data):
            res = json.loads(rec.Result())
            if res.get("text"):
                result_text.append(res["text"])
    
    # Get final result
    res = json.loads(rec.FinalResult())
    if res.get("text"):
        result_text.append(res["text"])
    
    proc.wait()
    return " ".join(result_text)

def type_text(text):
    """Type text using wtype (Wayland) and copy to clipboard."""
    if not text.strip():
        print("No text to type.", file=sys.stderr)
        return
    
    # Always copy to clipboard as a reliable fallback
    # We use -n to avoid adding a newline
    subprocess.run(["wl-copy", "-n", text])
    
    # Try to focus the previous window
    subprocess.run(["hyprctl", "dispatch", "focuswindow", "last"], capture_output=True)
    time.sleep(0.2)
    
    subprocess.run(["wtype", text])
    
    # Notify completion
    subprocess.run([
        "notify-send", "-t", "3000",
        "Dictation Complete", f"Text copied and typed: {text[:50]}..."
    ])

def main():
    parser = argparse.ArgumentParser(description="Voice dictation for Wayland")
    parser.add_argument("--no-type", action="store_true", help="Just print, don't type")
    parser.add_argument("--file", "-f", help="Transcribe from file instead of recording")
    args = parser.parse_args()
    
    # Handle toggle
    if not args.file and PID_FILE.exists():
        try:
            pid = int(PID_FILE.read_text().strip())
            os.kill(pid, signal.SIGTERM)
            sys.exit(0)
        except (ValueError, ProcessLookupError):
            PID_FILE.unlink()

    # Check dependencies
    for cmd in ["parecord", "ffmpeg", "wtype", "wl-copy", "hyprctl"]:
        if not subprocess.run(["command", "-v", cmd], capture_output=True, shell=True).returncode == 0:
            print(f"Warning: Command '{cmd}' not found.", file=sys.stderr)

    # Notify start
    subprocess.run([
        "notify-send", "-t", "2000",
        "Dictation", "🎤 Recording started..."
    ])
    
    if args.file:
        audio_path = args.file
    else:
        audio_path = record_audio()
    
    try:
        if not audio_path or not os.path.exists(audio_path) or os.path.getsize(audio_path) < 1000:
             return

        # Show that we are transcribing
        subprocess.run([
            "notify-send", "-t", "2000",
            "Dictation", "⌛ Transcribing..."
        ])
        
        text = transcribe(audio_path)
        
        if args.no_type:
            print(text)
        else:
            type_text(text)
    finally:
        # Cleanup temp file
        if not args.file and audio_path and os.path.exists(audio_path):
            os.unlink(audio_path)

if __name__ == "__main__":
    main()
