#!/bin/bash
# Update Antigravity from Downloads folder or download automatically
# Omarchy-specific version

set -e

DOWNLOAD_DIR="$HOME/Downloads/Antigravity"
TAR_FILE="$HOME/Downloads/Antigravity.tar.gz"
INSTALL_DIR="$HOME/.local/share/antigravity"
BIN_SYMLINK="$HOME/.local/bin/antigravity"
DESKTOP_ENTRY="$HOME/.local/share/applications/antigravity.desktop"
ICON_PATH="$HOME/.local/share/icons/antigravity.png"

AUTO_DOWNLOAD=false

usage() {
    echo "Usage: $0 [--download|-d]"
    echo "  --download, -d  Download latest version automatically"
    exit 1
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --download|-d)
            AUTO_DOWNLOAD=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

get_latest_version() {
    local page_content
    page_content=$(curl -sL "https://r.jina.ai/http://antigravity.google/download/linux" 2>/dev/null) || return 1
    
    local download_url
    download_url=$(echo "$page_content" | grep -oP 'https://edgedl\.me\.gvt1\.com/edgedl/release2/[^ ]*Antigravity\.tar\.gz' | head -1)
    
    if [[ -z "$download_url" ]]; then
        return 1
    fi
    
    local version
    version=$(echo "$download_url" | grep -oP 'stable/\K[0-9.]+(?=-[0-9]+/linux-x64)')
    
    echo "$version|$download_url"
}

if [[ "$AUTO_DOWNLOAD" == "true" ]]; then
    echo "Checking for latest Antigravity version..."
    
    OLD_VERSION=$(grep -o '"ideVersion": "[^"]*"' "$INSTALL_DIR/resources/app/product.json" 2>/dev/null | cut -d'"' -f4) || OLD_VERSION="none"
    
    echo "Installed version: v${OLD_VERSION:-unknown}"
    
    result=$(get_latest_version) || {
        echo "Error: Could not fetch latest version info"
        exit 1
    }
    
    NEW_VERSION=$(echo "$result" | cut -d'|' -f1)
    DOWNLOAD_URL=$(echo "$result" | cut -d'|' -f2)
    
    echo "Latest version: v$NEW_VERSION"
    
    if [[ "$OLD_VERSION" == "$NEW_VERSION" ]]; then
        echo "Already up to date!"
        exit 0
    fi
    
    echo "Downloading Antigravity v$NEW_VERSION..."
    rm -f "$TAR_FILE"
    if ! curl -L --progress-bar "$DOWNLOAD_URL" -o "$TAR_FILE"; then
        echo "Error: Download failed"
        rm -f "$TAR_FILE"
        exit 1
    fi
    echo "Download complete"
fi

if [[ -f "$TAR_FILE" ]]; then
    echo "Found Antigravity.tar.gz, extracting..."
    [[ -d "$DOWNLOAD_DIR" ]] && rm -rf "$DOWNLOAD_DIR"
    if ! tar -xzf "$TAR_FILE" -C "$HOME/Downloads/"; then
        echo "Error: Extraction failed"
        exit 1
    fi
    echo "Extracted to $DOWNLOAD_DIR"
fi

if [[ ! -d "$DOWNLOAD_DIR" ]] || [[ ! -f "$DOWNLOAD_DIR/antigravity" ]]; then
    echo "No new version found in $DOWNLOAD_DIR"
    echo "Please download Antigravity.tar.gz to ~/Downloads first"
    echo "Or run: $0 --download"
    exit 1
fi

OLD_VERSION=$(grep -o '"ideVersion": "[^"]*"' "$INSTALL_DIR/resources/app/product.json" 2>/dev/null | cut -d'"' -f4)
NEW_VERSION=$(grep -o '"ideVersion": "[^"]*"' "$DOWNLOAD_DIR/resources/app/product.json" 2>/dev/null | cut -d'"' -f4)

echo "Installed: v${OLD_VERSION:-unknown}"
echo "Downloaded: v${NEW_VERSION:-unknown}"

if [[ "$OLD_VERSION" == "$NEW_VERSION" ]]; then
    echo "Already up to date."
    [[ -d "$DOWNLOAD_DIR" ]] && rm -rf "$DOWNLOAD_DIR"
    [[ -f "$TAR_FILE" ]] && rm -f "$TAR_FILE"
    exit 0
fi

echo "Updating Antigravity to v$NEW_VERSION..."

mkdir -p "$(dirname "$INSTALL_DIR")"
mkdir -p "$(dirname "$BIN_SYMLINK")"
mkdir -p "$(dirname "$ICON_PATH")"
mkdir -p "$(dirname "$DESKTOP_ENTRY")"

[[ -d "$INSTALL_DIR" ]] && rm -rf "$INSTALL_DIR"
if ! cp -r "$DOWNLOAD_DIR"/* "$INSTALL_DIR"/; then
    echo "Error: Copying files failed"
    exit 1
fi
chmod +x "$INSTALL_DIR/antigravity"

if [[ ! -L "$BIN_SYMLINK" ]] || [[ "$(readlink "$BIN_SYMLINK")" != "$INSTALL_DIR/antigravity" ]]; then
    ln -sf "$INSTALL_DIR/antigravity" "$BIN_SYMLINK"
    echo "Symlink updated: $BIN_SYMLINK -> $INSTALL_DIR/antigravity"
fi

if [[ ! -f "$ICON_PATH" ]]; then
    if [[ -f "$DOWNLOAD_DIR"/data/share/icons/hicolor/512x512/apps/antigravity.png ]]; then
        cp "$DOWNLOAD_DIR"/data/share/icons/hicolor/512x512/apps/antigravity.png "$ICON_PATH"
    elif [[ -f "$DOWNLOAD_DIR"/data/share/icons/antigravity.png ]]; then
        cp "$DOWNLOAD_DIR"/data/share/icons/antigravity.png "$ICON_PATH"
    fi
fi

if [[ ! -f "$DESKTOP_ENTRY" ]] || [[ "$(grep "^Exec=" "$DESKTOP_ENTRY" 2>/dev/null | cut -d= -f2-)" != "$INSTALL_DIR/antigravity" ]]; then
    cat > "$DESKTOP_ENTRY" << EOF
[Desktop Entry]
Name=Antigravity
Comment=AI-powered IDE
Exec=$INSTALL_DIR/antigravity
Icon=$ICON_PATH
Terminal=false
Type=Application
Categories=Development;IDE;
EOF
    update-desktop-database "$(dirname "$DESKTOP_ENTRY")" 2>/dev/null
    echo "Desktop entry created/updated"
fi

rm -rf "$DOWNLOAD_DIR"
[[ -f "$TAR_FILE" ]] && rm -f "$TAR_FILE"
echo "Cleaned up Downloads"

echo "Done! Antigravity updated to v$NEW_VERSION"
